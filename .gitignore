# ========================
# `.gitignore` 通用模板
# 适用Python + 深度学习 项目 
# =========================

# =========================
# Python 基础
# =========================
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# =========================
# 虚拟环境（非常重要）
# =========================
.venv/
venv/
env/
ENV/
.env
.env.*

# =========================
# 打包 / 构建
# =========================
build/
dist/
*.egg-info/
.eggs/

# =========================
# 日志
# =========================
*.log

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# IDE
# =========================
.vscode/
.idea/

# =========================
# OS
# =========================
.DS_Store
Thumbs.db

# =========================
# 测试 / 缓存
# =========================
.pytest_cache/
.mypy_cache/
.cache/

# =========================
# 深度学习（重点！！）
# =========================

# 数据集
data/
datasets/

# 模型权重
weights/
*.pth
*.pt
*.ckpt
*.onnx
*.bin

# HuggingFace / transformers cache
.cache/huggingface/
transformers_cache/

# TensorBoard
runs/
logs/
events.out.tfevents.*

# wandb
wandb/

# 输出结果
outputs/
results/
checkpoints/

# 临时文件
tmp/
temp/

# =========================
# 多模态 / VLM 
# =========================
*.jpg
*.png
*.mp4
*.avi
*.npz
*.npy
*.h5

# 可选：如果数据在 repo 内
# data/*.jpg
# data/*.png